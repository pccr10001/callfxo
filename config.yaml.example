http:
  listen: ":8080"

sip:
  transport: "tcp"
  listen: "0.0.0.0:5060"
  realm: "callfxo"
  domain: "callfxo.local"
  advertised_ip: "192.168.1.33"
  contact_user: "callfxo"
  nonce_ttl_hours: 1

media:
  rtp_bind_ip: "0.0.0.0"
  public_ip: "192.168.1.33"
  ice_stun_urls:
    - "stun:stun.l.google.com:19302"

database:
  path: "./callfxo.db"

auth:
  # Access token used by API and WebSocket bearer auth.
  cookie_name: "callfxo_access"
  access_ttl_minutes: 60
  # Refresh token lifetime for app/web session recovery.
  refresh_ttl_hours: 720

fcm:
  # Optional. Leave disabled when you do not want Android/Web push notifications.
  enabled: false
  project_id: ""
  web_app_id: ""
  web_api_key: ""
  android_app_id: ""
  android_api_key: ""
  messaging_sender_id: ""
  auth_domain: ""
  storage_bucket: ""
  measurement_id: ""
  # Required for browser push subscription.
  vapid_key: ""
  # Path to the Firebase service account JSON used by the server to send FCM.
  service_account_json: ""

